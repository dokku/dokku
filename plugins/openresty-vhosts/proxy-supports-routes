#!/usr/bin/env bash
set -eo pipefail
[[ $DOKKU_TRACE ]] && set -x
source "$PLUGIN_CORE_AVAILABLE_PATH/common/functions"

trigger-openresty-vhosts-proxy-supports-routes() {
  declare desc="advertises path-based routing support for openresty (currently false)"
  declare trigger="proxy-supports-routes"
  declare APP="$1"

  if [[ "$(plugn trigger proxy-type "$APP")" != "openresty" ]]; then
    return
  fi

  # The openresty sidecar image does not yet accept path-prefix routing labels.
  # Tracked upstream at dokku/openresty-docker-proxy#137.
  echo "false"
}

trigger-openresty-vhosts-proxy-supports-routes "$@"
