#!/usr/bin/env bash
set -eo pipefail
[[ $DOKKU_TRACE ]] && set -x
source "$PLUGIN_CORE_AVAILABLE_PATH/common/functions"

trigger-traefik-vhosts-proxy-supports-routes() {
  declare desc="advertises path-based routing support for traefik"
  declare trigger="proxy-supports-routes"
  declare APP="$1"

  if [[ "$(plugn trigger proxy-type "$APP")" != "traefik" ]]; then
    return
  fi

  echo "true"
}

trigger-traefik-vhosts-proxy-supports-routes "$@"
